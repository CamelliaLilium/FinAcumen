.pytest_cache/
.coverage
htmlcov/
.tox/
*.cover

# --- Linting & Type Checking ---
.ruff_cache/
.mypy_cache/
.dmypy.json
.pytype/

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb

