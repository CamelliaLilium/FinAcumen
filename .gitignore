*.py[cod]
*.pyo
*.egg-info/
*.egg
dist/
build/
*.so
.Python
*.manifest
*.spec

# --- Virtual environments ---
venv/
.venv/
env/
.env
*.env

# --- API Keys & Secrets ---
*.env
.env.*
*secret*
*api_key*
*apikey*

# --- IDE & Editor ---
.idea/
.vscode/
*.swp
*.swo
*~
.claude/
.claire/
.cursor/
.sisyphus/
.opencode/
.githooks/

# --- OS Files ---
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

